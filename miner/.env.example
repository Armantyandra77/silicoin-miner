# REQUIRED - Your miner wallet private key (0x...)
# KEEP THIS SECRET - never share or commit to git!
PRIVATE_KEY=

# Ethereum RPC URL (public or private)
RPC_URL=https://eth.llamarpc.com

# Max gas price in gwei - pause mining above this
MAX_GAS_GWEI=20

# Total ETH budget for gas spending
BUDGET_ETH=0.02

# Mining backend: gpu | native | js  (auto-detect by default)
MINER_BACKEND=auto

# Display name for dashboard
MINER_NAME=My-RTX-Miner

# Enable telemetry reporting (on/off)
REPORT=on

# Bundle mode: flashbots | mempool (flashbots = builder bundles, more reliable)
BUNDLE=flashbots

# Number of CPU workers (0 = auto-detect)
WORKERS=0

# Flashbots RPC for bundles (optional - set for builder bundles)
FLASHBOTS_RPC=