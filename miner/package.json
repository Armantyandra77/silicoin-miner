{
  "name": "silicoin-miner",
  "version": "0.1.0",
  "description": "SLC/Silicoin proof-of-work miner for Ethereum mainnet (RTX GPU + CPU)",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:all": "npm run build",
    "bench": "tsx src/bench.ts",
    "status": "tsx src/status.ts",
    "mine": "tsx src/index.ts",
    "dev": "tsx src/index.ts",
    "gpu:check": "python3 gpu/gpu_miner.py --check",
    "gpu:install": "pip install torch --index-url https://download.pytorch.org/whl/cu121 pycryptodome"
  },
  "keywords": ["silicoin", "slc", "ethereum", "proof-of-work", "miner"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "viem": "^2.21.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsx": "^4.16.0",
    "@types/node": "^20.14.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}